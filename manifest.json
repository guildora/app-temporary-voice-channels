  "license": "MIT",
  "compatibility": {
    "core": {
      "minVersion": "0.1.0"
    }
  },
  "navigation": {
    "rail": [
      {
        "id": "your-app-id",
        "icon": "star",
        "label": "Your App",
        "to": "/apps/your-app-id",
        "order": 50,
        "requiredRoles": ["user"]
      }
    ],
    "panelGroups": [
      {
        "id": "your-app-id-group",
