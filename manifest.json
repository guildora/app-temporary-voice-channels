          {
            "id": "your-app-id-overview",
            "label": "Overview",
            "to": "/apps/your-app-id"
          },
          {
            "id": "your-app-id-admin",
            "label": "Manage",
            "to": "/apps/your-app-id/admin",
            "requiredRoles": ["moderator"]
          }
        ]
      }
    ]
  },
  "permissions": [
    {
      "id": "read:member",
      "label": "Read members",
      "description": "Read member profiles and roles"
    }
  ],
  "pages": [
    {
      "id": "your-app-id-overview",
      "path": "/apps/your-app-id",
      "title": "Overview",
      "requiredRoles": ["user"]
